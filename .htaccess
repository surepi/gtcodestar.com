<IfModule mod_rewrite.c>
  Options +FollowSymlinks
  RewriteEngine On

  # --- 1. 强制跳转到 HTTPS 和 www.gtcodestar.com ---
  # 如果不是以 www.gtcodestar.com 开头，或者不是 HTTPS 访问
  RewriteCond %{HTTP_HOST} ^gtcodestar\.com$ [NC,OR]
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://www.gtcodestar.com/$1 [L,R=301]

  # --- 2. 你原有的伪静态路由规则 ---
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^(.*)$ index.php?p=$1 [QSA,PT,L]
</IfModule>