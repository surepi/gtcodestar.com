# 禁止执行 PHP - 上传目录安全保护
# 生成时间: 2026-03-31

# 方法 1: 关闭 PHP 引擎
<IfModule mod_php5.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

# 方法 2: 将所有 PHP 文件作为纯文本处理
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar)$">
    SetHandler none
    SetHandler default-handler
    ForceType text/plain

    # 额外保护：直接拒绝访问
    Order Deny,Allow
    Deny from all
</FilesMatch>

# 方法 3: LiteSpeed 专用配置
<IfModule Litespeed>
    php_value engine Off
</IfModule>

# 禁止访问 .htaccess 本身
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

# 禁止访问其他隐藏文件
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 禁止目录列表
Options -Indexes

# 只允许特定文件类型
<FilesMatch "\.(jpg|jpeg|png|gif|webp|pdf|doc|docx|xls|xlsx|zip|rar|txt)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>
